#!/usr/bin/env zsh
set -euo pipefail
source "${0:A:h}/../lib/account-env.sh"
account="${1:-}"
agentic_export_env "$account"
shift

app_path="/Applications/Codex.app"
if [[ "$AGENTIC_ACCOUNT" == "corp" && -d "/Applications/Codex Work.app" ]]; then
  app_path="/Applications/Codex Work.app"
fi

if [[ -d "$app_path" ]]; then
  workspace="${1:-.}"
  app_exec="$(/usr/libexec/PlistBuddy -c 'Print :CFBundleExecutable' "$app_path/Contents/Info.plist" 2>/dev/null || true)"
  if [[ "$app_exec" == "codex-work-launcher" ]]; then
    exec open -n "$app_path"
  fi

  exec open -n -a "$app_path" \
    --env "AGENTIC_ACCOUNT=$AGENTIC_ACCOUNT" \
    --env "AGENTIC_ACCOUNTS_ROOT=$AGENTIC_ACCOUNTS_ROOT" \
    --env "AGENTIC_ACCOUNT_ROOT=$AGENTIC_ACCOUNT_ROOT" \
    --env "CODEX_HOME=$CODEX_HOME" \
    --env "XDG_CONFIG_HOME=$XDG_CONFIG_HOME" \
    --env "XDG_CACHE_HOME=$XDG_CACHE_HOME" \
    --env "XDG_DATA_HOME=$XDG_DATA_HOME" \
    --env "XDG_STATE_HOME=$XDG_STATE_HOME" \
    "$workspace"
fi

exec codex app "$@"
