#!/usr/bin/env python3
import argparse
import json
import os
import re
import select
import shutil
import subprocess
import sys
import termios
import time
from datetime import datetime
from types import SimpleNamespace
from pathlib import Path
import tty


KIT_ROOT = Path(__file__).resolve().parents[1]
BIN_DIR = KIT_ROOT / "bin"
SCRIPTS_DIR = KIT_ROOT / "scripts"


def color(text: str, code: str) -> str:
    if not sys.stdout.isatty() or os.environ.get("NO_COLOR"):
        return text
    return f"\033[{code}m{text}\033[0m"


def dim(text: str) -> str:
    return color(text, "2")


def bold(text: str) -> str:
    return color(text, "1")


def green(text: str) -> str:
    return color(text, "32")


def yellow(text: str) -> str:
    return color(text, "33")


def red(text: str) -> str:
    return color(text, "31")


def cyan(text: str) -> str:
    return color(text, "36")


def prog_name() -> str:
    return os.environ.get("AGENTIC_ENV_PROG", Path(sys.argv[0]).name)


def now_stamp() -> str:
    return datetime.now().strftime("%Y%m%d%H%M%S")


def account_root(account: str) -> Path:
    return Path(os.environ.get("AGENTIC_ACCOUNTS_ROOT", str(Path.home() / "AgenticAccounts"))) / account


def run(cmd, check=False):
    proc = subprocess.run(cmd, text=True, capture_output=True)
    if check and proc.returncode != 0:
        raise RuntimeError(proc.stderr.strip() or proc.stdout.strip() or f"command failed: {cmd}")
    return {
        "cmd": cmd,
        "ok": proc.returncode == 0,
        "exit_code": proc.returncode,
        "stdout": proc.stdout.strip(),
        "stderr": proc.stderr.strip(),
    }


def run_with_spinner(cmd):
    if not sys.stdout.isatty():
        return run(cmd)
    spinner = "|/-\\"
    proc = subprocess.Popen(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    idx = 0
    while proc.poll() is None:
        print(f"\r{cyan(spinner[idx % len(spinner)])} executando: {' '.join(cmd)}", end="", flush=True)
        idx += 1
        time.sleep(0.1)
    stdout, stderr = proc.communicate()
    print("\r" + " " * 80 + "\r", end="")
    return {
        "cmd": cmd,
        "ok": proc.returncode == 0,
        "exit_code": proc.returncode,
        "stdout": stdout.strip(),
        "stderr": stderr.strip(),
    }


def emit(args, payload, exit_code=0):
    if args.json:
        print(json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True))
    else:
        print_human(payload)
    return exit_code


def print_human(payload):
    if "summary" in payload:
        print(payload["summary"])
    for check in payload.get("checks", []):
        mark = "ok" if check.get("ok") else "fail"
        print(f"{mark}: {check.get('name')}")
        detail = check.get("detail")
        if detail:
            print(f"  {detail}")
    for step in payload.get("next_steps", []):
        print(f"- {step}")


def section(title: str):
    print()
    print(cyan("=" * 72))
    print(bold(title))
    print(cyan("=" * 72))


def choose(prompt: str, choices, default=None) -> str:
    if sys.stdin.isatty() and sys.stdout.isatty():
        return choose_tty(prompt, choices, default)
    return choose_plain(prompt, choices, default)


def choose_plain(prompt: str, choices, default=None) -> str:
    print()
    print(prompt)
    for idx, (key, label, detail) in enumerate(choices, 1):
        suffix = " [default]" if default == key else ""
        print(f"  {idx}. {label}{suffix}")
        if detail:
            print(f"     {detail}")
    print("  q. sair")
    while True:
        raw = input("> ").strip()
        if raw.lower() in {"q", "quit", "exit"}:
            raise KeyboardInterrupt
        if raw == "" and default:
            return default
        for idx, (key, _label, _detail) in enumerate(choices, 1):
            if raw == str(idx) or raw == key:
                return key
        print("Escolha inválida. Digite o número da opção.")


def read_key() -> str:
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        first = os.read(fd, 1)
        if first == b"\x1b":
            seq = first
            # Arrow keys can arrive as CSI (ESC [ A) or SS3 (ESC O A).
            # Read all immediately pending bytes so slow terminals do not
            # leave part of the escape sequence for the next menu loop.
            while select.select([sys.stdin], [], [], 0.12)[0]:
                seq += os.read(fd, 1)
                text = seq.decode("utf-8", "ignore")
                if text in {"\x1b[A", "\x1b[B", "\x1bOA", "\x1bOB"}:
                    return text
                if len(seq) >= 8:
                    return seq.decode("utf-8", "ignore")
            return seq.decode("utf-8", "ignore")
        return first.decode("utf-8", "ignore")
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)


def choose_tty(prompt: str, choices, default=None) -> str:
    selected = 0
    for idx, (key, _label, _detail) in enumerate(choices):
        if key == default:
            selected = idx
            break
    while True:
        print("\033[2J\033[H", end="")
        print(cyan(f"{prog_name()} configure"))
        print(dim("Use ↑/↓ ou j/k, Enter para selecionar, q para sair."))
        print()
        print(bold(prompt))
        for idx, (key, label, detail) in enumerate(choices):
            marker = ">" if idx == selected else " "
            line = f"{marker} {idx + 1}. {label}"
            if key == default:
                line += "  " + dim("[default]")
            print(color(line, "7") if idx == selected else line)
            if detail and idx == selected:
                print("   " + dim(detail))
        key = read_key()
        if key in {"q", "Q", "\x03"}:
            raise KeyboardInterrupt
        if key in {"\r", "\n"}:
            return choices[selected][0]
        if key in {"\x1b[A", "\x1bOA", "k", "K"}:
            selected = (selected - 1) % len(choices)
        elif key in {"\x1b[B", "\x1bOB", "j", "J"}:
            selected = (selected + 1) % len(choices)
        elif key.isdigit():
            value = int(key)
            if 1 <= value <= len(choices):
                return choices[value - 1][0]


def confirm(prompt: str, default: bool = False) -> bool:
    suffix = "S/n" if default else "s/N"
    while True:
        raw = input(f"{prompt} [{suffix}] ").strip().lower()
        if raw == "":
            return default
        if raw in {"s", "sim", "y", "yes"}:
            return True
        if raw in {"n", "nao", "não", "no"}:
            return False
        print("Responda com s ou n.")


def print_command(cmd: list[str]):
    print("$ " + " ".join(cmd))


def run_and_show(name: str, cmd: list[str], allow_fail: bool = False):
    print()
    print(bold(f"Step: {name}"))
    print_command(cmd)
    result = run_with_spinner(cmd)
    output = result["stdout"] or result["stderr"]
    if output:
        print(output)
    if not result["ok"] and not allow_fail:
        print(f"Falhou com exit code {result['exit_code']}.")
    return result


def print_table(rows):
    if not rows:
        return
    left = max(len(str(row[0])) for row in rows)
    right = max(len(str(row[1])) for row in rows)
    border = "+" + "-" * (left + 2) + "+" + "-" * (right + 2) + "+"
    print(cyan(border))
    for key, value in rows:
        print(f"| {str(key).ljust(left)} | {str(value).ljust(right)} |")
    print(cyan(border))


def input_repo(prompt: str):
    pattern = re.compile(r"^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$")
    while True:
        value = input(prompt).strip()
        if not value:
            return None
        if pattern.match(value):
            return value
        print(red("Formato invalido. Use org/repo, por exemplo IcaroAguiar/agentic-multi-account."))


def read_kv_file(path: Path):
    data = {}
    if not path.exists():
        return data
    for raw in path.read_text().splitlines():
        line = raw.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        data[key.strip()] = value.strip().strip('"').strip("'")
    return data


def write_kv_file(path: Path, values: dict, yes: bool):
    path.parent.mkdir(parents=True, exist_ok=True)
    old = path.read_text() if path.exists() else ""
    if path.exists():
        backup = path.with_suffix(path.suffix + f".backup.{now_stamp()}")
    else:
        backup = None
    lines = []
    seen = set()
    for raw in old.splitlines():
        key = raw.split("=", 1)[0].strip() if "=" in raw and not raw.strip().startswith("#") else None
        if key in values:
            lines.append(f"{key}={values[key]}")
            seen.add(key)
        else:
            lines.append(raw)
    for key, value in values.items():
        if key not in seen:
            lines.append(f"{key}={value}")
    if not yes:
        return {"would_write": str(path), "would_backup": str(backup) if backup else None, "content": "\n".join(lines) + "\n"}
    if backup:
        shutil.copy2(path, backup)
    path.write_text("\n".join(lines) + "\n")
    os.chmod(path, 0o600)
    return {"written": str(path), "backup": str(backup) if backup else None}


def command_status(args):
    root = account_root(args.account)
    inheritance = read_kv_file(root / "env" / "inheritance.env")
    paths = {
        "account_root": root,
        "codex_home": root / "codex",
        "codex_auth": root / "codex" / "auth.json",
        "github_config": Path(inheritance.get("AGENTIC_GH_CONFIG_DIR") or (str(Path.home() / ".config" / "gh") if inheritance.get("AGENTIC_INHERIT_GH") == "1" else str(root / "codex" / "github"))),
        "xdg_config": root / "xdg" / "config",
        "plugins": root / "codex" / "plugins",
        "mcp": root / "mcp",
        "workspaces": root / "workspaces",
    }
    checks = [{"name": name, "ok": path.exists(), "detail": str(path)} for name, path in paths.items()]
    payload = {
        "ok": all(c["ok"] for c in checks if c["name"] not in {"codex_auth", "plugins", "mcp"}),
        "command": "status",
        "account": args.account,
        "summary": f"status do ambiente {args.account}",
        "github_mode": "inherited-global" if inheritance.get("AGENTIC_INHERIT_GH") == "1" else "isolated",
        "checks": checks,
    }
    return emit(args, payload)


def command_doctor(args):
    checks = []
    doctor = run([str(BIN_DIR / "agentic-doctor"), args.account])
    checks.append({"name": "agentic-doctor", "ok": doctor["ok"], "detail": doctor["stdout"] or doctor["stderr"]})

    gh = run([str(BIN_DIR / "agentic-gh"), args.account, "auth", "status"])
    checks.append({"name": "github auth", "ok": gh["ok"], "detail": gh["stdout"] or gh["stderr"]})

    if args.private_repo:
        repo = run([str(BIN_DIR / "agentic-gh"), args.account, "repo", "view", args.private_repo, "--json", "nameWithOwner,viewerPermission"])
        checks.append({"name": f"github repo {args.private_repo}", "ok": repo["ok"], "detail": repo["stdout"] or repo["stderr"]})

    if args.codex:
        codex = run([str(BIN_DIR / "agentic-codex"), args.account, "doctor", "--summary"])
        checks.append({"name": "codex doctor", "ok": codex["ok"], "detail": codex["stdout"] or codex["stderr"]})

    payload = {
        "ok": all(c["ok"] for c in checks),
        "command": "doctor",
        "account": args.account,
        "summary": f"doctor do ambiente {args.account}",
        "checks": checks,
        "next_steps": github_next_steps(checks),
    }
    return emit(args, payload, 0 if payload["ok"] else 1)


def github_next_steps(checks):
    gh = next((c for c in checks if c["name"] == "github auth"), None)
    if not gh or gh["ok"]:
        return []
    detail = gh.get("detail", "")
    if "token in default is invalid" in detail:
        return ["O gh herdado está chegando ao ambiente, mas o token global está inválido: rode `gh auth login -h github.com` ou troque para modo isolado."]
    if "not logged into any GitHub hosts" in detail:
        return ["O gh isolado não está autenticado: rode `agentic-env link-github corp --mode isolated --yes` e depois `GH_CONFIG_DIR=\"$HOME/AgenticAccounts/corp/codex/github\" gh auth login -h github.com --web`."]
    return ["Reexecute `agentic-env --json doctor corp` após corrigir a autenticação do GitHub."]


def command_link_github(args):
    root = account_root(args.account)
    path = root / "env" / "inheritance.env"
    value = "1" if args.mode == "inherit" else "0"
    result = write_kv_file(path, {"AGENTIC_INHERIT_GH": value}, args.yes)
    payload = {
        "ok": True,
        "command": "link-github",
        "account": args.account,
        "mode": args.mode,
        "summary": f"github {args.account}: modo {args.mode}",
        "result": result,
        "next_steps": [
            "`agentic-env --json doctor %s`" % args.account,
            "`gh auth login -h github.com` se estiver herdando token global inválido" if args.mode == "inherit" else f"`GH_CONFIG_DIR=\"$HOME/AgenticAccounts/{args.account}/codex/github\" gh auth login -h github.com --web` para login isolado compatível com Codex Work",
        ],
    }
    return emit(args, payload)


def detect_shell():
    shell = Path(os.environ.get("SHELL", "")).name
    return shell or "sh"


def shell_snippet(shell: str):
    path_line = f'{BIN_DIR}:$PATH'
    if shell == "fish":
        return f"set -gx AGENTIC_MULTI_ACCOUNT_HOME {KIT_ROOT}\nset -gx AGENTIC_ACCOUNTS_ROOT $HOME/AgenticAccounts\nfish_add_path {BIN_DIR}\n"
    if shell in {"zsh", "bash", "sh"}:
        return f'export AGENTIC_MULTI_ACCOUNT_HOME="{KIT_ROOT}"\nexport AGENTIC_ACCOUNTS_ROOT="$HOME/AgenticAccounts"\nexport PATH="{path_line}"\n'
    return f"# shell não reconhecido: {shell}\n# adicione {BIN_DIR} ao PATH e defina AGENTIC_ACCOUNTS_ROOT.\n"


def shell_rc(shell: str):
    home = Path.home()
    if shell == "zsh":
        return home / ".zshrc"
    if shell == "bash":
        return home / ".bashrc"
    if shell == "fish":
        return home / ".config" / "fish" / "config.fish"
    return None


def github_status_label(detail: str, ok: bool) -> str:
    if ok:
        return green("ok")
    if "token in default is invalid" in detail:
        return red("token global invalido")
    if "not logged into any GitHub hosts" in detail:
        return yellow("sem login")
    return red("falha")


def collect_snapshot(account: str):
    root = account_root(account)
    inheritance = read_kv_file(root / "env" / "inheritance.env")
    gh_mode = "inherited-global" if inheritance.get("AGENTIC_INHERIT_GH") == "1" else "isolated"
    gh = run([str(BIN_DIR / "agentic-gh"), account, "auth", "status"])
    icon = Path("/Applications/Codex Work.app")
    icon_exec = ""
    if icon.exists():
        icon_exec_result = run(["/usr/libexec/PlistBuddy", "-c", "Print :CFBundleExecutable", str(icon / "Contents" / "Info.plist")])
        icon_exec = icon_exec_result["stdout"]
    shell = detect_shell()
    return {
        "account": account,
        "shell": shell,
        "shell_rc": str(shell_rc(shell)) if shell_rc(shell) else "manual",
        "root": root,
        "codex_home": root / "codex",
        "codex_auth": (root / "codex" / "auth.json").exists(),
        "claude_home": root / "claude",
        "opencode_home": root / "opencode",
        "gh_mode": gh_mode,
        "gh_ok": gh["ok"],
        "gh_detail": gh["stdout"] or gh["stderr"],
        "icon_ok": icon.exists() and icon_exec == "codex-work-launcher",
        "icon_exec": icon_exec or "missing",
    }


def print_dashboard(snapshot):
    print()
    print(bold(f"{snapshot['account']} environment"))
    print_table(
        [
            ("Shell", f"{snapshot['shell']}  {snapshot['shell_rc']}"),
            ("Codex home", snapshot["codex_home"]),
            ("Codex auth", "presente" if snapshot["codex_auth"] else "ausente"),
            ("Claude", snapshot["claude_home"]),
            ("OpenCode", snapshot["opencode_home"]),
            ("GitHub", f"{snapshot['gh_mode']}  {'ok' if snapshot['gh_ok'] else 'needs attention'}"),
            ("Codex Work", f"{'ok' if snapshot['icon_ok'] else 'requer validacao'}  {snapshot['icon_exec']}"),
        ]
    )


def dashboard_text(snapshot):
    return "\n".join(
        [
            f"{snapshot['account']} environment",
            f"Shell      {snapshot['shell']}  {snapshot['shell_rc']}",
            f"Codex      {snapshot['codex_home']}  auth={'yes' if snapshot['codex_auth'] else 'no'}",
            f"GitHub     {snapshot['gh_mode']}  {'ok' if snapshot['gh_ok'] else 'needs attention'}",
            f"Launcher   {'ok' if snapshot['icon_ok'] else 'needs validation'}",
            "",
            "Escolha a proxima acao:",
        ]
    )


def recommended_action(snapshot):
    if not snapshot["gh_ok"]:
        return "github"
    if not snapshot["icon_ok"] and snapshot["account"] == "corp":
        return "icon"
    return "smoke"


def command_setup(args):
    shell = detect_shell() if args.shell == "auto" else args.shell
    snippet = shell_snippet(shell)
    checks = [{"name": "detected shell", "ok": True, "detail": shell}]
    bootstrap = None
    if args.yes:
      bootstrap = run([str(SCRIPTS_DIR / "bootstrap-agentic-accounts.sh")])
      checks.append({"name": "bootstrap", "ok": bootstrap["ok"], "detail": bootstrap["stdout"] or bootstrap["stderr"]})
    rc = shell_rc(shell)
    if rc and args.yes:
        rc.parent.mkdir(parents=True, exist_ok=True)
        old = rc.read_text() if rc.exists() else ""
        if "AGENTIC_MULTI_ACCOUNT_HOME" not in old:
            backup = rc.with_suffix(rc.suffix + f".backup.{now_stamp()}")
            if rc.exists():
                shutil.copy2(rc, backup)
            with rc.open("a") as f:
                f.write("\n# agentic-multi-account\n")
                f.write(snippet)
            checks.append({"name": "shell integration", "ok": True, "detail": f"updated {rc}"})
        else:
            checks.append({"name": "shell integration", "ok": True, "detail": f"already present in {rc}"})
    payload = {
        "ok": all(c["ok"] for c in checks),
        "command": "setup",
        "summary": "setup do agentic-multi-account",
        "shell": shell,
        "snippet": snippet,
        "checks": checks,
        "next_steps": ["eval o snippet acima ou abra um novo shell", "`agentic-env --json doctor corp`"],
    }
    return emit(args, payload, 0 if payload["ok"] else 1)


def command_switch(args):
    root = account_root(args.account)
    lines = [
        f'export AGENTIC_ACCOUNT="{args.account}"',
        f'export AGENTIC_ACCOUNT_ROOT="{root}"',
        f'export CODEX_HOME="{root / "codex"}"',
        f'export XDG_CONFIG_HOME="{root / "xdg" / "config"}"',
        f'export XDG_CACHE_HOME="{root / "xdg" / "cache"}"',
        f'export XDG_DATA_HOME="{root / "xdg" / "data"}"',
        f'export XDG_STATE_HOME="{root / "xdg" / "state"}"',
    ]
    payload = {"ok": True, "command": "switch", "account": args.account, "summary": "\n".join(lines), "exports": lines}
    return emit(args, payload)


def command_install_icon(args):
    if not args.yes:
        payload = {
            "ok": True,
            "command": "install-icon",
            "summary": "dry-run: instalaria /Applications/Codex Work.app como launcher seguro",
            "next_steps": ["rode `agentic-env install-icon --yes` para aplicar", "remova e recoloque o item no Dock se o cache antigo persistir"],
        }
        return emit(args, payload)
    result = run([str(SCRIPTS_DIR / "install-codex-work-app.sh")])
    verify = run(["codesign", "--verify", "--deep", "--strict", "/Applications/Codex Work.app"])
    checks = [
        {"name": "install launcher", "ok": result["ok"], "detail": result["stdout"] or result["stderr"]},
        {"name": "codesign", "ok": verify["ok"], "detail": verify["stdout"] or verify["stderr"]},
    ]
    payload = {"ok": all(c["ok"] for c in checks), "command": "install-icon", "summary": "instalação do Codex Work launcher", "checks": checks}
    return emit(args, payload, 0 if payload["ok"] else 1)


def command_migrate(args):
    checks = []
    if not args.yes:
        payload = {"ok": True, "command": "migrate", "summary": "dry-run migrate", "next_steps": ["adicione --yes para executar sync de harness/plugins aprovado"]}
        return emit(args, payload)
    if args.harness:
        r = run([str(SCRIPTS_DIR / "sync-codex-harness.sh"), args.source, args.account])
        checks.append({"name": "sync harness", "ok": r["ok"], "detail": r["stdout"] or r["stderr"]})
    if args.plugins:
        r = run([str(SCRIPTS_DIR / "sync-codex-plugins.sh"), args.source, args.account])
        checks.append({"name": "sync plugins", "ok": r["ok"], "detail": r["stdout"] or r["stderr"]})
    payload = {"ok": all(c["ok"] for c in checks), "command": "migrate", "account": args.account, "checks": checks}
    return emit(args, payload, 0 if payload["ok"] else 1)


def command_reset_auth(args):
    root = account_root(args.account)
    targets = []
    if args.surface in {"codex", "all"}:
        targets.append(root / "codex" / "auth.json")
    if args.surface in {"github", "all"}:
        targets.append(root / "codex" / "github")
        targets.append(root / "github")
    actions = []
    for target in targets:
        if not target.exists():
            actions.append({"target": str(target), "ok": True, "detail": "missing"})
            continue
        backup = target.with_name(target.name + f".backup.{now_stamp()}")
        if args.yes:
            shutil.move(str(target), str(backup))
            actions.append({"target": str(target), "ok": True, "backup": str(backup)})
        else:
            actions.append({"target": str(target), "ok": True, "would_move_to": str(backup)})
    payload = {"ok": True, "command": "reset-auth", "account": args.account, "surface": args.surface, "actions": actions, "summary": "reset-auth com backup"}
    return emit(args, payload)


def command_rollback(args):
    backup_root = Path(os.environ.get("CODEX_WORK_BACKUP_ROOT", str(Path.home() / "AgenticAccounts" / "shared" / "backups")))
    backups = sorted(backup_root.glob("Codex Work.app.backup.*"))
    if not backups:
        return emit(args, {"ok": False, "command": "rollback", "summary": "nenhum backup de Codex Work.app encontrado"}, 1)
    latest = backups[-1]
    if not args.yes:
        return emit(args, {"ok": True, "command": "rollback", "summary": f"dry-run: restauraria {latest}", "backup": str(latest)})
    current = Path("/Applications/Codex Work.app")
    if current.exists():
        shutil.move(str(current), str(backup_root / f"Codex Work.app.before-rollback.{now_stamp()}"))
    shutil.copytree(latest, current)
    return emit(args, {"ok": True, "command": "rollback", "summary": f"restaurado {latest}"})


def command_smoke_test(args):
    args.codex = args.codex_doctor
    return command_doctor(args)


def command_configure(args):
    if args.json:
        payload = {
            "ok": False,
            "command": "configure",
            "error": {
                "type": "InteractiveOnly",
                "message": "configure é interativo. Use status/doctor/smoke-test com --json para automação.",
            },
        }
        print(json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True))
        return 2

    try:
        section(f"{prog_name()} configure")
        print("Configura ambientes isolados para Codex, Claude Code, OpenCode e GitHub.")
        print(dim("Auto-detecta shell, mostra estado atual e pede confirmacao antes de writes."))

        account = choose(
            "Escolha o ambiente",
            [
                ("corp", "Work/corp", "Conta de trabalho com auth, state, caches e workspaces separados."),
                ("personal", "Personal", "Conta pessoal, util para comparar e manter isolamento explicito."),
            ],
            default="corp",
        )

        while True:
            snapshot = collect_snapshot(account)
            if not sys.stdin.isatty():
                section(f"Estado atual: {account}")
                print_dashboard(snapshot)
            prompt = dashboard_text(snapshot) if sys.stdin.isatty() else "Escolha a proxima acao"
            action = choose(
                prompt,
                [
                    ("github", "Corrigir GitHub", "Escolher isolado/herdado e validar gh auth."),
                    ("shell", "Aplicar shell setup", "Detecta shell atual e instala PATH/bootstrap com backup."),
                    ("icon", "Instalar Codex Work", "Launcher com icone proprio; nao altera Codex.app original."),
                    ("share", "Migrar setup aprovado", "Sincroniza harness/plugins sem auth, sessoes ou historico."),
                    ("smoke", "Rodar smoke test", "Valida paths, GitHub e opcionalmente codex doctor."),
                    ("advanced", "Avancado", "Reset auth, rollback, exports e diagnostico detalhado."),
                    ("done", "Concluir", "Sair."),
                ],
                default=recommended_action(snapshot),
            )

            if action == "done":
                print("Concluído.")
                return 0

            if action == "shell":
                shell = detect_shell()
                section("Shell setup")
                print(f"Detectado: {bold(shell)}")
                print(f"Arquivo alvo: {shell_rc(shell) or 'manual'}")
                print()
                print(shell_snippet(shell))
                if confirm("Aplicar bootstrap e integração no arquivo rc do shell?", default=False):
                    setup_args = SimpleNamespace(json=False, shell=shell if shell in {"zsh", "bash", "fish", "sh"} else "sh", yes=True)
                    command_setup(setup_args)
                else:
                    print("Dry-run concluído. Nenhum arquivo alterado.")
                continue

            if action == "github":
                section("GitHub auth")
                print("Escolha por conta. Nao copiamos tokens e nao editamos ~/.config/gh sem voce pedir.")
                mode = choose(
                    "Modo GitHub",
                    [
                        ("isolated", "Isolado", f"Usa ~/AgenticAccounts/{account}/codex/github. Recomendado para Codex Work e sandbox."),
                        ("inherit", "Herdar global", "Usa ~/.config/gh. Conveniente, mas compartilha identidade do gh global."),
                    ],
                    default="isolated" if account == "corp" else "inherit",
                )
                print()
                if mode == "isolated":
                    print(f"Vai gravar AGENTIC_INHERIT_GH=0 para {account}.")
                    print("Proximo passo manual: gh-corp auth login -h github.com")
                else:
                    print(f"Vai gravar AGENTIC_INHERIT_GH=1 para {account}.")
                    print("Se o token global estiver invalido: gh auth login -h github.com")
                if confirm("Aplicar esta política de GitHub agora?", default=False):
                    link_args = SimpleNamespace(json=False, account=account, mode=mode, yes=True)
                    command_link_github(link_args)
                    run_and_show("github smoke", [str(BIN_DIR / "agentic-gh"), account, "auth", "status"], allow_fail=True)
                else:
                    print("Dry-run concluído. Nenhum arquivo alterado.")
                continue

            if action == "share":
                section("Migrar setup aprovado")
                print("Migração permitida: AGENTS, hooks, agents, plugins e configs aprovadas.")
                print("Migração bloqueada: auth.json, sessões, threads, logs, state DBs, caches sensíveis e tokens.")
                harness = confirm("Migrar harness/config aprovado?", default=True)
                plugins = confirm("Migrar plugins aprovados?", default=True)
                if confirm("Executar migração agora?", default=False):
                    migrate_args = SimpleNamespace(json=False, account=account, source=str(Path.home() / ".codex"), harness=harness, plugins=plugins, yes=True)
                    command_migrate(migrate_args)
                else:
                    print("Dry-run concluído. Nenhum arquivo alterado.")
                continue

            if action == "icon":
                section("Codex Work launcher")
                print("Estratégia segura: /Applications/Codex Work.app é launcher com ícone próprio.")
                print("Estratégia evitada: modificar o bundle Electron original ou uma cópia assinada.")
                if confirm("Instalar/atualizar o launcher Codex Work.app?", default=False):
                    icon_args = SimpleNamespace(json=False, yes=True)
                    command_install_icon(icon_args)
                else:
                    icon_args = SimpleNamespace(json=False, yes=False)
                    command_install_icon(icon_args)
                continue

            if action == "smoke":
                section("Smoke test")
                private_repo = input_repo("Repo privado esperado para validar acesso (opcional, formato org/repo): ")
                codex_doctor = confirm("Incluir codex doctor --summary?", default=False)
                smoke_args = SimpleNamespace(json=False, account=account, private_repo=private_repo, codex_doctor=codex_doctor)
                command_smoke_test(smoke_args)
                continue

            if action == "advanced":
                advanced = choose(
                    "Avancado",
                    [
                        ("diagnose", "Diagnostico detalhado", "Roda status e doctor em JSON."),
                        ("auth", "Reset auth com backup", "Move auth Codex/GitHub para backup."),
                        ("switch", "Mostrar exports", "Imprime variaveis para ativar a conta no shell atual."),
                        ("rollback", "Rollback icone", "Restaura backup anterior de Codex Work.app."),
                        ("back", "Voltar", "Retorna ao menu principal."),
                    ],
                    default="diagnose",
                )
                if advanced == "back":
                    continue
                if advanced == "diagnose":
                    run_and_show("status", [str(Path.home() / ".local" / "bin" / "agentic-env"), "--json", "status", account], allow_fail=True)
                    run_and_show("doctor", [str(Path.home() / ".local" / "bin" / "agentic-env"), "--json", "doctor", account], allow_fail=True)
                elif advanced == "auth":
                    surface = choose(
                        "Qual auth mover para backup?",
                        [
                            ("codex", "Codex auth", "Move auth.json da conta selecionada para backup."),
                            ("github", "GitHub auth isolado", "Move diretorios github isolados da conta para backup."),
                            ("all", "Codex + GitHub", "Move ambos para backup."),
                        ],
                        default="codex",
                    )
                    print("Nenhum token sera impresso. O reset move arquivos para backup; nao apaga direto.")
                    reset_args = SimpleNamespace(json=False, account=account, surface=surface, yes=confirm("Executar reset-auth com backup agora?", default=False))
                    command_reset_auth(reset_args)
                elif advanced == "switch":
                    switch_args = SimpleNamespace(json=False, account=account)
                    command_switch(switch_args)
                    print()
                    print("Para aplicar no shell atual, copie/cole os exports acima.")
                elif advanced == "rollback":
                    rollback_args = SimpleNamespace(json=False, target="icon", yes=confirm("Restaurar ultimo backup de Codex Work.app?", default=False))
                    command_rollback(rollback_args)
                continue

    except KeyboardInterrupt:
        print()
        print("Configuração cancelada. Nenhuma ação pendente foi aplicada.")
        return 130


def build_parser():
    parser = argparse.ArgumentParser(prog=os.environ.get("AGENTIC_ENV_PROG", Path(sys.argv[0]).name), description="Diagnostica e mantém ambientes isolados Codex pessoal/work.")
    parser.add_argument("-j", "--json", action="store_true", help="emite JSON estável")
    sub = parser.add_subparsers(dest="command")

    p = sub.add_parser("status", help="mostra paths e modo de isolamento")
    p.add_argument("account", choices=["personal", "corp"])
    p.set_defaults(func=command_status)

    p = sub.add_parser("doctor", help="diagnóstico de conta, Codex e GitHub")
    p.add_argument("account", choices=["personal", "corp"])
    p.add_argument("-r", "--private-repo", help="repo privado esperado, ex: org/repo")
    p.add_argument("-c", "--codex", action="store_true", help="também roda codex doctor")
    p.set_defaults(func=command_doctor)

    p = sub.add_parser("setup", help="bootstrap e snippet por shell")
    p.add_argument("-s", "--shell", choices=["auto", "zsh", "bash", "fish", "sh"], default="auto")
    p.add_argument("-y", "--yes", action="store_true", help="aplica bootstrap e integração no rc do shell")
    p.set_defaults(func=command_setup)

    p = sub.add_parser("switch", help="imprime exports para ativar uma conta no shell atual")
    p.add_argument("account", choices=["personal", "corp"])
    p.set_defaults(func=command_switch)

    p = sub.add_parser("link-github", help="define GitHub isolado ou herdado por conta")
    p.add_argument("account", choices=["personal", "corp"])
    p.add_argument("-m", "--mode", choices=["isolated", "inherit"], required=True)
    p.add_argument("-y", "--yes", action="store_true", help="grava env/inheritance.env com backup")
    p.set_defaults(func=command_link_github)

    p = sub.add_parser("install-icon", help="instala Codex Work.app como launcher seguro")
    p.add_argument("-y", "--yes", action="store_true")
    p.set_defaults(func=command_install_icon)

    p = sub.add_parser("migrate", help="migra harness/plugins aprovados para uma conta")
    p.add_argument("account", choices=["personal", "corp"])
    p.add_argument("-f", "--from", dest="source", default=str(Path.home() / ".codex"))
    p.add_argument("-H", "--harness", action="store_true")
    p.add_argument("-P", "--plugins", action="store_true")
    p.add_argument("-y", "--yes", action="store_true")
    p.set_defaults(func=command_migrate)

    p = sub.add_parser("reset-auth", help="move auth para backup; não apaga sem backup")
    p.add_argument("account", choices=["personal", "corp"])
    p.add_argument("-S", "--surface", choices=["codex", "github", "all"], required=True)
    p.add_argument("-y", "--yes", action="store_true")
    p.set_defaults(func=command_reset_auth)

    p = sub.add_parser("rollback", help="restaura backup do Codex Work.app")
    p.add_argument("target", choices=["icon"])
    p.add_argument("-y", "--yes", action="store_true")
    p.set_defaults(func=command_rollback)

    p = sub.add_parser("smoke-test", help="executa smoke tests de isolamento e GitHub")
    p.add_argument("account", choices=["personal", "corp"])
    p.add_argument("-r", "--private-repo")
    p.add_argument("-c", "--codex-doctor", action="store_true")
    p.set_defaults(func=command_smoke_test)

    p = sub.add_parser("configure", help="fluxo interativo guiado com escolhas e validações")
    p.set_defaults(func=command_configure)

    p = sub.add_parser("config", help="alias de configure")
    p.set_defaults(func=command_configure)

    p = sub.add_parser("wizard", help="alias legado de configure")
    p.set_defaults(func=command_configure)
    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()
    if args.command is None:
        args.func = command_configure
    try:
        return args.func(args)
    except KeyboardInterrupt:
        if args.json:
            print(json.dumps({"ok": False, "command": getattr(args, "command", None), "error": {"type": "KeyboardInterrupt", "message": "cancelado pelo usuario"}}, ensure_ascii=False, indent=2, sort_keys=True))
        else:
            print()
            print(yellow("Operacao cancelada. Nenhuma acao pendente foi aplicada."))
        return 130
    except Exception as exc:
        payload = {"ok": False, "command": getattr(args, "command", None), "error": {"type": exc.__class__.__name__, "message": str(exc)}}
        if args.json:
            print(json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True))
        else:
            print(f"error: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    sys.exit(main())
