# Copy to a repository as .envrc and change the expected account.
export AGENTIC_EXPECTED_ACCOUNT=corp
source "${AGENTIC_MULTI_ACCOUNT_HOME:-$HOME/src/agentic-multi-account}/lib/account-env.sh"
agentic_export_env "$AGENTIC_EXPECTED_ACCOUNT"

if [[ "$(pwd)" != "$AGENTIC_ACCOUNT_ROOT/workspaces/"* ]]; then
  echo "warning: repo is outside $AGENTIC_ACCOUNT_ROOT/workspaces"
fi
